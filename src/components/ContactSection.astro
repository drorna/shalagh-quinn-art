---
// The form opens the visitor's email client (mailto:) pre-filled with their
// data, so the message arrives at this address as a real email from the
// visitor. Clicking "Reply" in Gmail goes straight back to them with no
// quoted form-data clutter.
const RECIPIENT_EMAIL = "shalaghquinns@gmail.com";
---

<section class="contact" id="contact" aria-labelledby="contact-title">
  <div class="container contact__inner">
    <header class="contact__head reveal">
      <p class="eyebrow contact__eyebrow">Get in touch</p>
      <h2 id="contact-title" class="contact__title">
        Let&rsquo;s create.<br />
        <span>mural inquiries, commissions,<br />and portrait photography.</span>
      </h2>

      <ul class="contact__direct">
        <li>
          <span class="contact__direct-label">Email</span>
          <a href={`mailto:${RECIPIENT_EMAIL}`}>{RECIPIENT_EMAIL}</a>
        </li>
        <li>
          <span class="contact__direct-label">Studio</span>
          <span>By appointment</span>
        </li>
        <li>
          <span class="contact__direct-label">Instagram</span>
          <a href="https://instagram.com/shalagh" target="_blank" rel="noopener noreferrer">@shalagh</a>
        </li>
      </ul>
    </header>

    <form class="contact__form reveal" data-mailto-form data-recipient={RECIPIENT_EMAIL} novalidate>
      <div class="contact__row">
        <label class="contact__field">
          <span class="contact__label">Name</span>
          <input type="text" name="Name" required autocomplete="name" />
        </label>
        <label class="contact__field">
          <span class="contact__label">Email</span>
          <input type="email" name="Email" required autocomplete="email" />
        </label>
      </div>

      <div class="contact__row">
        <label class="contact__field">
          <span class="contact__label">Phone <span class="contact__optional">(optional)</span></span>
          <input type="tel" name="Phone" autocomplete="tel" placeholder="+1 (555) 123-4567" />
        </label>
        <label class="contact__field">
          <span class="contact__label">What&rsquo;s this about?</span>
          <select name="Inquiry Type">
            <option value="Mural commission">Mural commission</option>
            <option value="Painting commission">Painting commission</option>
            <option value="Portrait commission">Portrait commission</option>
            <option value="Photography session">Photography session</option>
            <option value="Press / press inquiry">Press / press inquiry</option>
            <option value="Just saying hello">Just saying hello</option>
          </select>
        </label>
      </div>

      <label class="contact__field">
        <span class="contact__label">Message</span>
        <textarea
          name="Message"
          rows="6"
          required
          placeholder="Tell me about your space, your idea, or what you&rsquo;re hoping to make."
        ></textarea>
      </label>

      {/* Honeypot — bots fill this, humans don't see it */}
      <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="contact__honey" aria-hidden="true" />

      <div class="contact__submit-row">
        <p class="contact__small">Pressing send opens your email app with the message ready to send.</p>
        <button type="submit" class="contact__submit">
          <span>Send message</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>

      <p class="contact__fallback" data-mailto-fallback hidden>
        <strong>If your email app didn&rsquo;t open</strong>, just send a message
        directly to <a href={`mailto:${RECIPIENT_EMAIL}`}>{RECIPIENT_EMAIL}</a>.
      </p>
    </form>

    <script>
      const form = document.querySelector<HTMLFormElement>("[data-mailto-form]");
      const fallback = document.querySelector<HTMLElement>("[data-mailto-fallback]");

      if (form) {
        const recipient = form.dataset.recipient || "";

        form.addEventListener("submit", (e) => {
          e.preventDefault();

          // Drop spam from honeypot
          const honey = (form.elements.namedItem("_honey") as HTMLInputElement | null)?.value;
          if (honey) return;

          const data = new FormData(form);
          const name = (data.get("Name") as string || "").trim();
          const email = (data.get("Email") as string || "").trim();
          const phone = (data.get("Phone") as string || "").trim();
          const inquiry = (data.get("Inquiry Type") as string || "").trim();
          const message = (data.get("Message") as string || "").trim();

          // Soft validation (browsers usually catch via required, but novalidate is set)
          if (!name || !email || !message) {
            form.reportValidity();
            return;
          }

          const subject = inquiry ? `${inquiry} — ${name}` : `Website inquiry — ${name}`;

          const bodyLines = [
            message,
            "",
            "—",
            `From: ${name}`,
            `Email: ${email}`,
          ];
          if (phone) bodyLines.push(`Phone: ${phone}`);
          if (inquiry) bodyLines.push(`Inquiry: ${inquiry}`);

          const body = bodyLines.join("\n");

          const mailto = `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

          // Show fallback after a short delay if mailto handler is missing
          let opened = false;
          window.addEventListener("blur", () => { opened = true; }, { once: true });

          window.location.href = mailto;

          window.setTimeout(() => {
            if (!opened && fallback) {
              fallback.hidden = false;
              fallback.scrollIntoView({ behavior: "smooth", block: "center" });
            }
          }, 1200);
        });
      }
    </script>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--sp-16);
    background: linear-gradient(180deg, var(--color-paper) 0%, var(--color-paper-warm) 100%);
    border-top: 1px solid var(--color-line-soft);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
  }

  .contact__head {
    max-width: 520px;
  }

  .contact__eyebrow {
    margin: 0 0 var(--sp-3);
    color: var(--color-name);
  }

  .contact__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    margin: 0 0 var(--sp-4);
  }

  .contact__title span {
    color: var(--color-ink);
    display: block;
    font-size: 0.55em;
    margin-top: 0.4em;
    line-height: 1.25;
    color: var(--color-ink-soft);
    font-style: italic;
  }

  .contact__lede {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0 0 var(--sp-6);
    max-width: 44ch;
  }

  .contact__direct {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    border-top: 1px solid var(--color-line-soft);
    padding-top: var(--sp-4);
  }

  .contact__direct li {
    display: grid;
    grid-template-columns: 90px 1fr;
    align-items: baseline;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--fs-base);
  }

  .contact__direct-label {
    font-family: var(--font-meta);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-ink-mute);
  }

  .contact__direct a {
    color: var(--color-ink);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .contact__direct a:hover {
    border-bottom-color: var(--color-ink);
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    background: var(--color-paper);
    padding: var(--sp-4);
    border: 1px solid var(--color-line-soft);
  }

  .contact__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-3);
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact__label {
    font-family: var(--font-meta);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-ink-mute);
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
  }

  .contact__optional {
    text-transform: none;
    letter-spacing: 0;
    font-size: var(--fs-xs);
    color: var(--color-ink-mute);
    opacity: 0.7;
    font-style: italic;
  }

  .contact__form input,
  .contact__form select,
  .contact__form textarea {
    border: 0;
    border-bottom: 1px solid var(--color-line);
    background: transparent;
    padding: 10px 0;
    font-family: var(--font-body);
    font-size: var(--fs-base);
    color: var(--color-ink);
    transition: border-color var(--duration-fast) var(--ease-out);
    border-radius: 0;
  }

  .contact__form select {
    appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, var(--color-ink-mute) 50%),
                      linear-gradient(135deg, var(--color-ink-mute) 50%, transparent 50%);
    background-position: calc(100% - 14px) 50%, calc(100% - 8px) 50%;
    background-size: 6px 6px;
    background-repeat: no-repeat;
    padding-right: 24px;
    color-scheme: dark;
  }

  .contact__form select option {
    background-color: var(--color-paper-warm);
    color: var(--color-ink);
    padding: 8px;
  }

  .contact__form textarea {
    resize: vertical;
    min-height: 140px;
    padding: 10px 0;
    line-height: 1.6;
  }

  .contact__form input:focus,
  .contact__form select:focus,
  .contact__form textarea:focus {
    outline: 0;
    border-bottom-color: var(--color-ink);
  }

  .contact__honey {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact__submit-row {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--sp-2);
    align-items: stretch;
    margin-top: var(--sp-2);
  }

  .contact__small {
    margin: 0;
    font-family: var(--font-meta);
    font-size: var(--fs-xs);
    color: var(--color-ink-mute);
    line-height: 1.5;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0.95rem 1.6rem;
    background: var(--color-ink);
    color: var(--color-paper);
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    font-weight: 500;
    border-radius: 999px;
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .contact__submit svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .contact__submit:hover {
    background: var(--color-name);
  }

  .contact__submit:hover svg {
    transform: translateX(3px);
  }

  .contact__fallback {
    margin: var(--sp-3) 0 0;
    padding: var(--sp-3);
    background: var(--color-paper-warm);
    border: 1px solid var(--color-line);
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .contact__fallback a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-ink);
  }

  @media (min-width: 700px) {
    .contact__row {
      grid-template-columns: 1fr 1fr;
    }
    .contact__submit-row {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (min-width: 900px) {
    .contact__inner {
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--sp-12);
    }
    .contact__form {
      padding: var(--sp-6);
    }
  }
</style>
