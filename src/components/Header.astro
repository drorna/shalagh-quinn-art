---
interface Props {
  hideContactLink?: boolean;
}
const { hideContactLink = false } = Astro.props;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const contactHref = isHome ? "#contact" : "/#contact";
---

<header class="site-header" data-header>
  <div class="site-header__inner container">
    <a href="/" class="site-header__brand" aria-label="Shalagh Quinn — Home">
      <span class="site-header__brand-name">shalagh</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/#work">Work</a>
      <a href="/murals/">Murals</a>
      <a href="/painting/">Painting</a>
      <a href="/portraits/">Portraits</a>
      <a href="/photography/">Photography</a>
    </nav>

    {!hideContactLink && (
      <a href={contactHref} class="site-header__cta" data-contact-link>
        <span>Get in touch</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    )}
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding-block: var(--sp-3);
    transition:
      background-color var(--duration-base) var(--ease-out),
      padding var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
    border-bottom: 1px solid transparent;
  }

  .site-header.is-scrolled {
    background-color: rgba(250, 246, 239, 0.86);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    padding-block: var(--sp-2);
    border-bottom-color: var(--color-line-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
  }

  .site-header__brand-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--color-name);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: var(--sp-4);
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    color: var(--color-ink-soft);
  }

  .site-header__nav a {
    position: relative;
    padding-block: 4px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__nav a::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .site-header__nav a:hover {
    color: var(--color-ink);
  }

  .site-header__nav a:hover::after {
    transform: scaleX(1);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding-block: 4px;
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink);
    background: transparent;
    border-radius: 0;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__cta::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(1);
    transform-origin: left center;
    transition:
      transform var(--duration-base) var(--ease-out),
      background-color var(--duration-base) var(--ease-out);
  }

  .site-header__cta svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .site-header__cta:hover {
    color: var(--color-name);
  }

  .site-header__cta:hover::after {
    background-color: var(--color-name);
  }

  .site-header__cta:hover svg {
    transform: translateX(2px);
  }

  @media (min-width: 900px) {
    .site-header__nav {
      display: flex;
    }
  }

  @media (min-width: 768px) {
    .site-header__brand-name {
      font-size: 1.875rem;
    }
  }
</style>
