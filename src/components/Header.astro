---
interface Props {
  hideContactLink?: boolean;
}
const { hideContactLink = false } = Astro.props;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const contactHref = isHome ? "#contact" : "/#contact";
---

<header class="site-header" data-header>
  <div class="site-header__inner container">
    <a href="/" class="site-header__brand" aria-label="Shalagh Quinn — Home">
      <span class="site-header__brand-name">shalagh</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/#work">Work</a>
      <a href="/murals/">Murals</a>
      <a href="/painting/">Painting</a>
      <a href="/portraits/">Portraits</a>
      <a href="/photography/">Photography</a>
    </nav>

    <div class="site-header__actions">
      <button type="button" class="site-header__share" data-share aria-label="Share this site">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M11 4.5a2 2 0 1 0-2-2 2 2 0 0 0 .07.5L5.62 5.06a2 2 0 1 0 0 5.88l3.45 2.06a2 2 0 1 0 .43-.85L6.05 10.09a2 2 0 0 0 0-2.18l3.45-2.06A2 2 0 0 0 11 6.5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
        <span>Share</span>
      </button>

      {!hideContactLink && (
        <a href={contactHref} class="site-header__cta" data-contact-link>
          <span>Get in touch</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      )}
    </div>
  </div>

  <div class="share-toast" data-share-toast hidden role="status" aria-live="polite">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
      <path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>Link copied</span>
  </div>
</header>

<script>
  const shareBtn = document.querySelector<HTMLButtonElement>("[data-share]");
  const toast = document.querySelector<HTMLElement>("[data-share-toast]");

  if (shareBtn) {
    shareBtn.addEventListener("click", async () => {
      const shareData = {
        title: "Shalagh Quinn — Artist",
        text: "Murals, paintings, portraits and portrait photography by Shalagh Quinn.",
        url: window.location.origin + "/",
      };

      try {
        if (navigator.share) {
          await navigator.share(shareData);
          return;
        }
      } catch (err) {
        // User cancelled the share — do nothing
        if ((err as Error).name === "AbortError") return;
      }

      // Fallback: copy URL to clipboard
      try {
        await navigator.clipboard.writeText(shareData.url);
        if (toast) {
          toast.hidden = false;
          toast.classList.add("is-visible");
          window.setTimeout(() => {
            toast.classList.remove("is-visible");
            window.setTimeout(() => { toast.hidden = true; }, 280);
          }, 1800);
        }
      } catch {
        // Last resort: prompt user with the URL
        window.prompt("Copy this link:", shareData.url);
      }
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding-block: var(--sp-3);
    transition:
      background-color var(--duration-base) var(--ease-out),
      padding var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
    border-bottom: 1px solid transparent;
  }

  .site-header.is-scrolled {
    background-color: rgba(12, 10, 8, 0.78);
    backdrop-filter: saturate(140%) blur(14px);
    -webkit-backdrop-filter: saturate(140%) blur(14px);
    padding-block: var(--sp-2);
    border-bottom-color: var(--color-line-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
  }

  .site-header__brand-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--color-brand);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: var(--sp-4);
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    color: var(--color-ink-soft);
  }

  .site-header__nav a {
    position: relative;
    padding-block: 4px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__nav a::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .site-header__nav a:hover {
    color: var(--color-ink);
  }

  .site-header__nav a:hover::after {
    transform: scaleX(1);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }

  .site-header__share {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-block: 4px;
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink-soft);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__share:hover {
    color: var(--color-brand);
  }

  .site-header__share svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .site-header__share:hover svg {
    transform: rotate(-8deg);
  }

  .site-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding-block: 4px;
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink);
    background: transparent;
    border-radius: 0;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__cta::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(1);
    transform-origin: left center;
    transition:
      transform var(--duration-base) var(--ease-out),
      background-color var(--duration-base) var(--ease-out);
  }

  .site-header__cta svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .site-header__cta:hover {
    color: var(--color-name);
  }

  .site-header__cta:hover::after {
    background-color: var(--color-name);
  }

  .site-header__cta:hover svg {
    transform: translateX(2px);
  }

  /* Share toast */
  .share-toast {
    position: fixed;
    inset: auto 0 var(--sp-4) 0;
    z-index: 60;
    margin: 0 auto;
    width: max-content;
    max-width: 90vw;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.7rem 1.1rem;
    background: var(--color-ink);
    color: var(--color-paper);
    font-family: var(--font-meta);
    font-size: var(--fs-sm);
    font-weight: 500;
    border-radius: 999px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
    pointer-events: none;
  }

  .share-toast[hidden] { display: none; }

  .share-toast.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .share-toast svg {
    color: var(--color-brand);
  }

  /* On small screens hide the "Share" word, keep just icon */
  @media (max-width: 480px) {
    .site-header__share span { display: none; }
  }

  @media (min-width: 900px) {
    .site-header__nav {
      display: flex;
    }
  }

  @media (min-width: 768px) {
    .site-header__brand-name {
      font-size: 1.875rem;
    }
  }
</style>
